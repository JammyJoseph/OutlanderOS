generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ===== AUTH & USERS =====
model User {
  id            String    @id @default(cuid())
  email         String    @unique
  password      String
  name          String
  role          Role      @default(MEMBER)
  avatarUrl     String?
  department       String?
  avatar           String?
  startDate        DateTime?
  holidayAllowance Int      @default(25)
  salary           Float?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  contacts        Contact[]
  campaigns       Campaign[]       @relation("CampaignCreator")
  productions     Production[]     @relation("ProductionLead")
  editorialPieces EditorialPiece[] @relation("Writer")
  deadlines       Deadline[]       @relation("userDeadlines")
  assignedTasks   Task[]           @relation("assignedTasks")
  createdTasks    Task[]           @relation("createdTasks")
  notifications   Notification[]
  holidayRequests HolidayRequest[]
}

// ===== TASKS =====
model Task {
  id           String    @id @default(cuid())
  title        String
  description  String?
  dueDate      DateTime?
  status       String    @default("TODO") // TODO, IN_PROGRESS, DONE
  priority     String    @default("MEDIUM") // LOW, MEDIUM, HIGH, URGENT
  portal       String?   // commercial, production, print, editorial, finance
  link         String?   // deep link to related item
  assignedTo   User      @relation("assignedTasks", fields: [assignedToId], references: [id])
  assignedToId String
  createdBy    User      @relation("createdTasks", fields: [createdById], references: [id])
  createdById  String
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

// ===== NOTIFICATIONS =====
model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  type      String   // task_assigned, deal_moved, deadline_approaching, callsheet_published, payment_received
  message   String
  link      String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

// ===== HOLIDAY REQUESTS =====
model HolidayRequest {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  startDate  DateTime
  endDate    DateTime
  type       String   @default("ANNUAL") // ANNUAL, SICK, PERSONAL, OTHER
  status     String   @default("PENDING") // PENDING, APPROVED, REJECTED
  approvedBy String?
  notes      String?
  createdAt  DateTime @default(now())
}

enum Role {
  ADMIN
  MEMBER
}

// ===== CONTACTS BLACKBOOK =====
model Contact {
  id              String    @id @default(cuid())
  name            String
  email           String?
  phone           String?
  company         String?
  role            String?
  category        String
  tags            String[]
  instagram       String?
  website         String?
  notes           String?
  lastInteraction DateTime?
  createdBy       String
  creator         User      @relation(fields: [createdBy], references: [id])
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  clientCampaigns Campaign[]       @relation("ClientContact")
  productionCrew  ProductionCrew[]
  eventGuests     EventGuest[]
}

// ===== COMMERCIAL =====
model Client {
  id            String    @id @default(cuid())
  name          String
  industry      String?
  brandColor    String?
  xeroContactId String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  campaigns  Campaign[]
  printPages PrintPage[]
}

model Campaign {
  id               String         @id @default(cuid())
  clientId         String
  client           Client         @relation(fields: [clientId], references: [id])
  title            String
  type             CampaignType
  status           CampaignStatus @default(BRIEF_RECEIVED)
  value            Float?
  currency         String         @default("GBP")
  margin           Float?
  timelineStart    DateTime?
  timelineEnd      DateTime?
  mediaPlan        Json?
  ioUrl            String?
  ioSigned         Boolean        @default(false)
  ioSignedAt       DateTime?
  paymentTerms     String?
  notes            String?
  createdById      String
  createdBy        User           @relation("CampaignCreator", fields: [createdById], references: [id])
  billingContactId String?
  billingContact   Contact?       @relation("ClientContact", fields: [billingContactId], references: [id])
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  deliverables     Deliverable[]
  assets           CampaignAsset[]
  reports          CampaignReport[]
  production       Production?
  mediaPlans       MediaPlan[]
  intelligenceLogs IntelligenceLog[]
}

enum CampaignType {
  SUPPLIED_ASSET
  BESPOKE_PRODUCTION
  WHITE_LABEL
  EDITORIAL_FEATURE
  PRINT_AD
}

enum CampaignStatus {
  BRIEF_RECEIVED
  BRIEF_RESPONDED
  BOOKED
  LIVE
  DELIVERED
  PAID
  ARCHIVED
}

model Deliverable {
  id          String    @id @default(cuid())
  campaignId  String
  campaign    Campaign  @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  type        String
  description String?
  dueDate     DateTime?
  completed   Boolean   @default(false)
  completedAt DateTime?
  postedUrl   String?
  performance Json?
}

model CampaignAsset {
  id         String   @id @default(cuid())
  campaignId String
  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  fileName   String
  fileUrl    String
  fileType   String
  uploadedBy String
  uploadedAt DateTime @default(now())
}

model CampaignReport {
  id           String    @id @default(cuid())
  campaignId   String
  campaign     Campaign  @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  generatedAt  DateTime  @default(now())
  data         Json
  sentToClient Boolean   @default(false)
  sentAt       DateTime?
}

// ===== PRODUCTION =====
model Production {
  id           String           @id @default(cuid())
  campaignId   String?          @unique
  campaign     Campaign?        @relation(fields: [campaignId], references: [id])
  title        String
  clientName   String?
  brief        String?
  description  String?
  figmaUrl     String?
  status       ProductionStatus @default(DRAFT)
  budgetTotal  Float?
  budgetActual Float?
  marginTarget Float?
  shootDates   DateTime[]
  leadId       String?
  lead         User?            @relation("ProductionLead", fields: [leadId], references: [id])
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  callSheets CallSheet[]
  expenses   ProductionExpense[]
  crew       ProductionCrew[]
}

enum ProductionStatus {
  DRAFT
  BRIEFED
  PRE_PRODUCTION
  SHOOTING
  POST_PRODUCTION
  DELIVERED
  ARCHIVED
}

enum CallSheetStatus {
  DRAFT
  SAVED
  PUBLISHED
}

model CallSheet {
  id            String          @id @default(cuid())
  productionId  String
  production    Production      @relation(fields: [productionId], references: [id], onDelete: Cascade)
  status        CallSheetStatus @default(DRAFT)
  shootDate     DateTime
  callTime      String          @default("08:00")
  location      Json
  schedule      Json
  crew          Json
  notes         String?
  distributedAt DateTime?
  createdAt     DateTime        @default(now())
}

model ProductionExpense {
  id           String     @id @default(cuid())
  productionId String
  production   Production @relation(fields: [productionId], references: [id], onDelete: Cascade)
  category     String
  description  String
  amount       Float
  receiptUrl   String?
  approvedBy   String?
  createdAt    DateTime   @default(now())
}

model ProductionCrew {
  id           String     @id @default(cuid())
  productionId String
  production   Production @relation(fields: [productionId], references: [id], onDelete: Cascade)
  contactId    String
  contact      Contact    @relation(fields: [contactId], references: [id])
  role         String
  dayRate      Float?
  confirmed    Boolean    @default(false)
}

// ===== PRINT =====
model PrintIssue {
  id        String    @id @default(cuid())
  title     String
  year      Int
  pageCount Int       @default(0)
  status    String    @default("planning")
  printer   String?
  printDate DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  pages        PrintPage[]
  distribution PrintDistribution[]
}

model PrintPage {
  id         String      @id @default(cuid())
  issueId    String
  issue      PrintIssue  @relation(fields: [issueId], references: [id], onDelete: Cascade)
  pageNumber Int
  type       String
  clientId   String?
  client     Client?     @relation(fields: [clientId], references: [id])
  assignedTo String?
  status     String      @default("planned")
  contentUrl String?
}

model PrintDistribution {
  id        String     @id @default(cuid())
  issueId   String
  issue     PrintIssue @relation(fields: [issueId], references: [id], onDelete: Cascade)
  warehouse String
  quantity  Int
  shippedAt DateTime?
  tracking  String?
}

// ===== EDITORIAL =====
model EditorialPiece {
  id           String    @id @default(cuid())
  title        String
  type         String
  writerId     String?
  writer       User?     @relation("Writer", fields: [writerId], references: [id])
  editor       String?
  status       String    @default("pitch")
  deadline     DateTime?
  wordCount    Int?
  printPageId  String?
  publishedUrl String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  notes EditorialNote[]
}

model EditorialNote {
  id        String         @id @default(cuid())
  pieceId   String
  piece     EditorialPiece @relation(fields: [pieceId], references: [id], onDelete: Cascade)
  author    String
  content   String
  createdAt DateTime       @default(now())
}

// ===== EVENTS =====
model Event {
  id        String    @id @default(cuid())
  title     String
  type      String
  date      DateTime
  venue     String?
  capacity  Int?
  rsvpCount Int       @default(0)
  status    String    @default("planning")
  budget    Float?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  guests EventGuest[]
}

model EventGuest {
  id         String   @id @default(cuid())
  eventId    String
  event      Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  contactId  String?
  contact    Contact? @relation(fields: [contactId], references: [id])
  name       String
  email      String?
  rsvpStatus String   @default("invited")
  checkedIn  Boolean  @default(false)
}

// ===== INTELLIGENCE ENGINE =====
model IntelligenceLog {
  id         String    @id @default(cuid())
  runId      String
  campaignId String?
  campaign   Campaign? @relation(fields: [campaignId], references: [id])
  type       String    // status_update | io_signed | value_update | flag | no_change | error
  finding    String
  action     String?
  confidence Float     @default(0)
  sources    String[]
  rawData    Json?
  createdAt  DateTime  @default(now())
}

// ===== MEDIA PLANS =====
model MediaPlan {
  id           String    @id @default(cuid())
  campaignId   String?
  campaign     Campaign? @relation(fields: [campaignId], references: [id])
  clientName   String
  campaignName String
  flightStart  DateTime?
  flightEnd    DateTime?
  currency     String    @default("GBP")
  contactName  String?
  contactEmail String?
  status       String    @default("draft")
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  lineItems MediaPlanLineItem[]
}

// ===== DEADLINES =====
model Deadline {
  id           String    @id @default(cuid())
  title        String
  description  String?
  dueDate      DateTime
  source       String
  sourceRef    String?
  sourceUrl    String?
  type         String
  status       String    @default("ACTIVE")
  priority     String    @default("MEDIUM")
  assignedTo   String
  user         User      @relation("userDeadlines", fields: [assignedTo], references: [id])
  createdBy    String?
  emailFrom    String?
  emailSnippet String?
  completedAt  DateTime?
  snoozedUntil DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model MediaPlanLineItem {
  id                String    @id @default(cuid())
  mediaPlanId       String
  mediaPlan         MediaPlan @relation(fields: [mediaPlanId], references: [id], onDelete: Cascade)
  site              String
  startDate         DateTime?
  endDate           DateTime?
  placement         String
  rate              Float     @default(0)
  rateType          String    @default("Flat Fee")
  discount          Float     @default(0)
  units             Int       @default(1)
  grossCost         Float     @default(0)
  netCost           Float     @default(0)
  projectedCreative String?
  deliveryStatus    String    @default("planned")
  sortOrder         Int       @default(0)
}

// ===== THINK TANK (Cultural Intelligence) =====
model TrendSignal {
  id          String   @id @default(cuid())
  title       String
  source      String
  sourceUrl   String?
  category    String
  summary     String?
  sentiment   String?
  relevance   Int      @default(50)
  trending    Boolean  @default(false)
  tags        String[] @default([])
  upvotes     Int      @default(0)
  flagged     Boolean  @default(false)
  aiAnalysis  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([category])
  @@index([source])
  @@index([createdAt])
}

model BrandWatch {
  id          String    @id @default(cuid())
  name        String
  category    String?
  description String?
  logoUrl     String?
  keywords    String[]  @default([])
  signalCount Int       @default(0)
  heatScore   Int       @default(50)
  trajectory  String    @default("stable")
  lastChecked DateTime?
  notes       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model TrendReport {
  id          String   @id @default(cuid())
  title       String
  type        String
  content     String
  period      String?
  brandId     String?
  generatedBy String   @default("ai")
  createdAt   DateTime @default(now())

  @@index([type])
  @@index([createdAt])
}

// ===== CULTURAL CALENDAR =====
model CulturalEvent {
  id          String    @id @default(cuid())
  title       String
  date        DateTime
  endDate     DateTime?
  category    String
  subcategory String?
  location    String?
  description String?
  source      String?
  sourceUrl   String?
  importance  Int       @default(50)
  recurring   Boolean   @default(false)
  tags        String[]  @default([])
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}
