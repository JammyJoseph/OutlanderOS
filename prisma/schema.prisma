generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ===== AUTH & USERS =====
model User {
  id               String    @id @default(cuid())
  email            String    @unique
  password         String
  name             String
  role             Role      @default(MEMBER)
  avatarUrl        String?
  department       String?
  avatar           String?
  theme            String    @default("light") // "light" | "dark" — UI theme preference
  startDate        DateTime?
  holidayAllowance Int       @default(25)
  salary           Float?

  // Staff management — team assignments (e.g. ["COMMERCIAL","PRODUCTION"]),
  // active status (deactivated users can't log in), and last login time.
  teams       Json?     @default("[]")
  isActive    Boolean   @default(true)
  lastLoginAt DateTime?

  // Onboarding: new staff get a temporary password and must change it on first
  // login; hasSeenWelcome gates the one-time welcome screen after that.
  mustChangePassword Boolean @default(false)
  hasSeenWelcome     Boolean @default(false)

  googleAccessToken  String?
  googleRefreshToken String?
  googleTokenExpiry  DateTime?
  googleEmail        String? // which Google account is connected
  googleConnected    Boolean   @default(false)
  lastEmailScanAt    DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  contacts        Contact[]
  campaigns       Campaign[]       @relation("CampaignCreator")
  assignedDeals   Campaign[]       @relation("CampaignAssignee")
  productions     Production[]     @relation("ProductionLead")
  editorialPieces EditorialPiece[] @relation("Writer")
  deadlines       Deadline[]       @relation("userDeadlines")
  assignedTasks   Task[]           @relation("assignedTasks")
  createdTasks    Task[]           @relation("createdTasks")
  notifications   Notification[]
  holidayRequests HolidayRequest[]
  assignedMilestones ProductionMilestone[] @relation("milestoneAssignee")
}

// ===== TASKS =====
model Task {
  id              String    @id @default(cuid())
  title           String
  description     String?
  dueDate         DateTime?
  status          String    @default("TODO") // TODO, IN_PROGRESS, DONE
  priority        String    @default("MEDIUM") // LOW, MEDIUM, HIGH, URGENT
  portal          String? // commercial, production, print, editorial, finance
  link            String? // deep link to related item
  assignedTo      User      @relation("assignedTasks", fields: [assignedToId], references: [id])
  assignedToId    String
  createdBy       User      @relation("createdTasks", fields: [createdById], references: [id])
  createdById     String
  escalatedAt     DateTime? // last time auto-ping raised this task
  escalationLevel Int       @default(0) // 0 none, 1 HIGH, 2 URGENT, 3 7-day alert sent
  staleFlaggedAt  DateTime? // set when flagged as stalled in-progress
  taskType        String    @default("ACTION") // ACTION = needs doing now, TRACK = actioned, monitoring
  completedAt     DateTime? // set when status flips to DONE — drives the "last 7 days" completed view
  projectId       String? // linked Commercial deal (Campaign)
  project         Campaign? @relation("campaignTasks", fields: [projectId], references: [id])
  productionId    String? // linked Production project
  production      Production? @relation("productionLinkedTasks", fields: [productionId], references: [id])
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

// ===== NOTIFICATIONS =====
model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  type      String // task_assigned, deal_moved, deadline_approaching, callsheet_published, payment_received
  message   String
  link      String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

// ===== HOLIDAY REQUESTS =====
model HolidayRequest {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  startDate  DateTime
  endDate    DateTime
  type       String   @default("ANNUAL") // ANNUAL, SICK, PERSONAL, OTHER
  status     String   @default("PENDING") // PENDING, APPROVED, REJECTED
  approvedBy String?
  notes      String?
  createdAt  DateTime @default(now())
}

enum Role {
  ADMIN
  MEMBER
}

// ===== CONTACTS BLACKBOOK =====
model Contact {
  id              String    @id @default(cuid())
  name            String
  email           String?
  phone           String?
  company         String?
  role            String?
  category        String
  tags            String[]
  instagram       String?
  website         String?
  location        String?
  rating          Int? // 1–5
  isFavourite     Boolean   @default(false) // starred contact — pinned to the top of the directory
  archived        Boolean   @default(false) // soft-archived — hidden from the directory but not deleted
  archivedAt      DateTime? // when the contact was archived
  notes           String?
  portfolioLinks  Json      @default("[]") // [{ title: string, url: string }] — work/portfolio links
  // ── Instagram scanner (Directory Intelligence) ──
  source          String? // "instagram_scan" for scanned contacts; null for manual entries
  scanSource      String? // handle of the profile whose credit-scan surfaced this contact
  confidence      String? // VERIFIED | LIKELY | UNVERIFIED — how sure we are about scanned data
  followers       Int? // follower count captured at scan time
  profilePic      String? // profile picture URL captured at scan time
  recentPosts     Json      @default("[]") // [{ shortcode, imageUrl, caption? }] — most recent posts captured at scan time
  collaborations  Json      @default("[]") // [{ contactId?, handle, count, lastProject?, role? }] — who they've worked with
  scannedAt       DateTime? // last time this contact's profile was scraped
  // ── Print Directory: keyboard-filed shortlist for the printed directory ──
  printTier       Int? // 1 (top priority) | 2 (strong) | 3 (maybe) — filed via 1/2/3 keys
  printTierAt     DateTime? // when the contact was filed into its current print tier
  // ── Outlander Radar: emerging talent / accounts to watch ──
  isRadar         Boolean   @default(false)
  radarStatus     String? // WATCHING | REACHED_OUT | CONNECTED | COLLABORATING
  radarLink       String? // handle / profile link for radar entries
  lastInteraction DateTime?
  createdBy       String
  creator         User      @relation(fields: [createdBy], references: [id])
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  clientCampaigns Campaign[]       @relation("ClientContact")
  productionCrew  ProductionCrew[]
  eventGuests     EventGuest[]
}

// Caches Instagram scrape results so the same handle isn't re-scraped within 24h.
// Keyed by (handle, kind) where kind is "profile" or "credits".
model ScanCache {
  id        String   @id @default(cuid())
  handle    String
  kind      String   @default("profile") // profile | credits
  data      Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([handle, kind])
}

// ===== COMMERCIAL =====
model Client {
  id            String    @id @default(cuid())
  name          String
  industry      String?
  brandColor    String?
  xeroContactId String?
  archived      Boolean   @default(false)
  archivedAt    DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  campaigns  Campaign[]
  printPages PrintPage[]
}

model Campaign {
  id               String         @id @default(cuid())
  clientId         String
  client           Client         @relation(fields: [clientId], references: [id])
  title            String
  type             CampaignType // legacy single type — kept for backwards compatibility
  dealTypes        String[]       @default([]) // multi-select deal types, e.g. ["EVENT", "DIGITAL_PARTNERSHIP"]
  workflowType     String         @default("CREATIVE_BRIEF") // CREATIVE_BRIEF | SUPPLIED_ASSETS — determines the process, not the content type
  jobType          String         @default("CREATIVE_BRIEF") // CREATIVE_BRIEF | SUPPLIED_ASSETS | PRINT_AD — the user-facing job classifier set at deal creation; drives auto-tags + workflowType
  status           CampaignStatus @default(BRIEF_RECEIVED)
  stage            DealStage      @default(NEW_BRIEF)
  stageUpdatedAt   DateTime?
  description      String?
  dueDate          DateTime?
  budgetBreakdown  Json? // [{ category: string, amount: number }] — legacy splits, kept in sync with allocations
  marginPercent    Float? // company margin as % of the total deal budget (e.g. 30.0)
  marginAmount     Float? // company margin in £
  allocations      Json? // [{ name: string, amount: number, isProductionBudget: boolean }]
  budgetLocked     Boolean        @default(false)
  budgetLockedAt   DateTime?
  budgetLockedBy   String? // userId who locked the budget
  assignedToId     String?
  assignedTo       User?          @relation("CampaignAssignee", fields: [assignedToId], references: [id])
  value            Float?
  currency         String         @default("GBP")
  margin           Float?
  timelineStart    DateTime?
  timelineEnd      DateTime?
  mediaPlan          Json? // legacy spreadsheet-style media plan — kept for backwards compat, no longer built in the UI
  mediaPlanVersion   Int       @default(1)
  mediaPlanUpdatedAt DateTime?
  mediaPlanUpdatedBy String? // display name of the last editor
  mediaPlanLockedAt  DateTime?
  // ── Simplified media plan (upload/link) + deal economics ──
  mediaPlanLink      String? // Google Sheets URL — the externally-built media plan
  mediaPlanFile      String? // path to an uploaded PDF of the final media plan
  dealValue          Float? // total deal value taken from the media plan — feeds everything downstream
  mediaSpend         Float? // portion of the deal value spent on media (100% margin, no hard costs)
  productionMarginPct Float? // company side of the production margin split (e.g. 60 = 60/40)
  ioUrl            String?
  ioSigned         Boolean        @default(false)
  ioSignedAt       DateTime?
  briefContent     String? // creative brief for the production team
  briefDueDate     DateTime? // when the brief is due to production
  briefStatus      String         @default("DRAFT") // DRAFT, READY, SENT_TO_PRODUCTION
  // Creative workflow (CREATIVE_BRIEF deals): the client brief, Outlander's
  // creative response, and the client feedback log.
  clientBrief      Json? // { content, references: string[], receivedDate, responseDueDate }
  creativeResponse Json? // { treatment, moodBoardLinks: string[], sentDate, revisions: [{ treatment, moodBoardLinks, sentDate }] }
  clientFeedback   Json? // [{ date, from, text, type: 'note'|'revision'|'approval' }]
  creativeStatus   String? // AWAITING_RESPONSE | RESPONSE_SENT | IN_REVIEW | REVISIONS_REQUESTED | APPROVED
  isWhiteLabel     Boolean        @default(false) // deal delivered under the client's own brand, not Outlander's
  lastSyncedToProduction DateTime? // last time deal changes were pushed to the linked Production
  paymentTerms     String?
  notes            String?
  archived         Boolean        @default(false)
  archivedAt       DateTime?
  archivedById     String? // userId who archived the deal
  archivedByName   String? // display name captured at archive time
  stageAtArchive   String? // pipeline stage when the deal was archived
  createdById      String
  createdBy        User           @relation("CampaignCreator", fields: [createdById], references: [id])
  billingContactId String?
  billingContact   Contact?       @relation("ClientContact", fields: [billingContactId], references: [id])
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  deliverables     Deliverable[]
  assets           CampaignAsset[]
  reports          CampaignReport[]
  production       Production?
  mediaPlans       MediaPlan[]
  intelligenceLogs IntelligenceLog[]
  activities       DealActivity[]
  tasks            Task[]            @relation("campaignTasks")
  rounds           CreativeRound[]
}

// Creative Rounds — the iterative brief → submit → review → approve loop for a
// deal. Each round is either INTERNAL (Outlander team ideation) or CLIENT
// (pitched to the client). Replaces the older single clientBrief/creativeResponse
// blobs; those stay on Campaign for backwards compatibility.
model CreativeRound {
  id           String   @id @default(cuid())
  campaignId   String
  campaign     Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  roundNumber  Int
  type         String   // INTERNAL or CLIENT
  status       String   @default("IN_PROGRESS") // IN_PROGRESS, SUBMITTED, REVIEWED, APPROVED, REVISION_NEEDED
  title        String?  // e.g. "V1 Ideas", "Client Pitch 1"
  brief        String?  @db.Text // Brief/notes for this round
  feedback     String?  @db.Text // Review feedback
  deadline     DateTime?
  submittedAt  DateTime?
  reviewedAt   DateTime?
  deckUrl      String?  // Figma link or deck URL
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([campaignId])
}

enum DealStage {
  // ── current simplified pipeline ──
  NEW_BRIEF
  PITCHING_FEEDBACK
  APPROVAL
  SIGN_OFF
  IO_SIGNED_KICK_OFF
  IN_PRODUCTION
  LIVE
  COMPLETED
  PAID
  // ── legacy — folded onto the above via normalizeStage() ──
  LEAD
  PITCHED
  DEAL_SIGNED
  CREATIVE_BRIEF
  CREATIVE_REVIEW
  CREATIVE_APPROVED
  IO_SIGNED
  CLEARED_FOR_PRODUCTION
  NEGOTIATING
  BRIEF_RECEIVED
  CREATIVE_RESPONSE
  CLIENT_REVIEW
  CLIENT_APPROVED
  CONTRACTED
  BUDGET_SET
}

model DealActivity {
  id         String   @id @default(cuid())
  campaignId String
  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  type       String // created | stage_change | budget_update | field_update | note | deliverable | project_started
  message    String
  meta       Json?
  userId     String?
  userName   String?
  createdAt  DateTime @default(now())

  @@index([campaignId, createdAt])
  @@index([createdAt])
}

enum CampaignType {
  SUPPLIED_ASSET
  BESPOKE_PRODUCTION
  WHITE_LABEL
  EDITORIAL_FEATURE
  PRINT_AD
  PARTNERSHIP
  ADVERTORIAL
  EVENT
  EDITORIAL
}

enum CampaignStatus {
  BRIEF_RECEIVED
  BRIEF_RESPONDED
  BOOKED
  LIVE
  DELIVERED
  PAID
  ARCHIVED
}

model Deliverable {
  id          String    @id @default(cuid())
  campaignId  String
  campaign    Campaign  @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  title       String? // explicit title — falls back to `type` for legacy rows
  type        String
  quantity    Int       @default(1)
  description String?
  dueDate     DateTime?
  status      String    @default("PENDING") // PENDING, IN_PROGRESS, DELIVERED
  completed   Boolean   @default(false)
  completedAt DateTime?
  postedUrl   String? // "Live Link" — pasted when the post/asset goes live
  performance Json?
  // ── Scope creep: deliverables added AFTER the deal is signed ──
  isAdditional Boolean  @default(false)
  overageCost  Float? // extra charge to the client for this additional deliverable
  approvedBy   String? // who signed off the overage
  approvedAt   DateTime?
  // Live-go-live scheduling status for the supplied-asset campaign tracker:
  // PENDING | SCHEDULED | LIVE | LATE — distinct from the delivery `status`.
  scheduleStatus String @default("PENDING")
  createdAt   DateTime  @default(now())
}

model CampaignAsset {
  id         String   @id @default(cuid())
  campaignId String
  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  fileName   String
  fileUrl    String
  fileType   String
  uploadedBy String
  uploadedAt DateTime @default(now())
}

model CampaignReport {
  id           String    @id @default(cuid())
  campaignId   String
  campaign     Campaign  @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  generatedAt  DateTime  @default(now())
  data         Json
  sentToClient Boolean   @default(false)
  sentAt       DateTime?
}

// ===== PRODUCTION =====
model Production {
  id               String           @id @default(cuid())
  campaignId       String?          @unique
  campaign         Campaign?        @relation(fields: [campaignId], references: [id])
  trelloCardId     String? // linked Trello deal card (Commercial pipeline)
  type             String           @default("EDITORIAL") // EDITORIAL | COMMERCIAL — COMMERCIAL projects are created from Commercial portal with a locked budget
  // Colour-coding / billing classification, independent of `type`'s budget-lock
  // semantics: EDITORIAL (green) vs PAID (gold). COMMERCIAL productions are
  // always treated as PAID for colour purposes. Set at creation, editable in
  // the Overview tab.
  billingType      String           @default("EDITORIAL") // EDITORIAL | PAID
  campaignBudgetId String? // links back to the CampaignBudget that spawned this production
  title            String
  clientName       String?
  brief            String?
  description      String?
  figmaUrl         String?
  status           ProductionStatus @default(DRAFT)
  budgetTotal      Float?
  budgetActual     Float?
  marginTarget     Float?
  productionBudgetStatus String? // BUDGETING | LOCKED | IN_PROGRESS | FINAL
  productionLockedAt     DateTime?
  productionLockedBy     String? // userId who locked the production budget
  budgetMarkupPercent    Float? // agency/production-company markup applied to the budget subtotal
  budgetVatPercent       Float? // VAT rate applied on top of (subtotal + markup); defaults to 20% in the UI
  shootDates       DateTime[]
  // Editorial discount: % knocked off APA reference rates in the budget for
  // editorial productions (billingType EDITORIAL). Null = no discount applied.
  editorialRateDiscount Float?
  // Catering quote tracking (Phase 3D): caterers contacted from the Directory
  // with their response status. [{ contactId, name, email, phone, status, notes, contactedAt }]
  cateringQuotes   Json             @default("[]")
  // Structured production brief auto-generated when a Commercial deal is cleared
  // for production (Phase 4F): { clientName, budget, deliverables, timeline,
  // creativeDirection, targetAudience, generatedAt, dealId }
  briefData        Json?
  archived         Boolean          @default(false)
  archivedAt       DateTime?
  // Google Drive integration (per-user OAuth). Root folder "[Client] — [Project]"
  // holding Assets / Selects / Approved / Reference sub-folders. Created lazily
  // via /api/productions/[id]/drive/setup and reused thereafter.
  driveFolderId    String?
  leadId           String?
  lead             User?            @relation("ProductionLead", fields: [leadId], references: [id])
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  callSheets CallSheet[]
  expenses   ProductionExpense[]
  crew       ProductionCrew[]

  budgetItems      BudgetLineItem[]        @relation("productionBudget")
  productionTasks  ProductionTask[]        @relation("productionTasks")
  teamMembers      ProductionTeamMember[]  @relation("productionTeam")
  creativeAssets   CreativeAsset[]         @relation("productionCreative")
  scheduleBlocks   ScheduleBlock[]         @relation("productionSchedule")
  prodDeliverables ProductionDeliverable[] @relation("productionDeliverables")
  milestones       ProductionMilestone[]   @relation("productionMilestones")
  shareLinks       ProductionShareLink[]   @relation("productionShareLinks")
  linkedTasks      Task[]                  @relation("productionLinkedTasks")
}

// Shareable internal deep-link to a production. Any signed-in Outlander user
// (@outlandermag.com) can mint one; the token redirects straight into the
// project portal. Budget is never exposed through this — the target is the
// normal production page which enforces its own access.
model ProductionShareLink {
  id           String     @id @default(cuid())
  token        String     @unique
  productionId String
  production   Production @relation("productionShareLinks", fields: [productionId], references: [id], onDelete: Cascade)
  createdBy    String // userId who created the link
  expiresAt    DateTime?
  createdAt    DateTime   @default(now())
}

model BudgetLineItem {
  id           String     @id @default(cuid())
  productionId String
  production   Production @relation("productionBudget", fields: [productionId], references: [id], onDelete: Cascade)
  category     String
  section      String? // industry-standard grouping: PRE_PRODUCTION | CAST_TALENT | CREW | STYLING_GLAM | LOCATIONS | EQUIPMENT | TRANSPORT | CATERING | ART_DEPARTMENT | POST_PRODUCTION
  role         String? // specific role/item name (e.g. "DOP", "Lead Talent", "Lighting Kit")
  quantity     Float? // number of days/units
  rate         Float? // £ per unit (unit cost)
  vatPercent   Float? // per-line VAT rate; null treated as the 20% default in the UI
  description  String
  budgeted     Float      @default(0) // = quantity × rate when both set, else manual
  actual       Float      @default(0)
  notes        String?
  // Invoice tracking (Phase 4D). invoiceStatus:
  // NOT_INVOICED | INVOICE_RECEIVED | UNDER_REVIEW | APPROVED | PAID
  invoiceStatus  String?
  invoiceUrl     String? // uploaded/linked invoice PDF
  poNumber       String? // purchase order number
  invoicedAmount Float? // amount actually invoiced (may differ from budgeted/actual)
  sortOrder    Int        @default(0)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

model ProductionTask {
  id           String     @id @default(cuid())
  productionId String
  production   Production @relation("productionTasks", fields: [productionId], references: [id], onDelete: Cascade)
  title        String
  description  String?
  owner        String?
  dueDate      DateTime?
  status       String     @default("LOCKED")
  dependsOn    String?
  sortOrder    Int        @default(0)
  unlockedAt   DateTime? // set when auto-ping unlocks this run-on task
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

model ProductionTeamMember {
  id           String     @id @default(cuid())
  productionId String
  production   Production @relation("productionTeam", fields: [productionId], references: [id], onDelete: Cascade)
  name         String
  role         String
  email        String?
  phone        String?
  rate         Float?
  ratePer      String?
  status       String     @default("SUGGESTED")
  notes        String?
  // Dietary requirement collected before the call sheet is sent (Phase 3C).
  // Free text e.g. "No restrictions", "Vegetarian", "Halal", "Gluten-free".
  dietaryRequirements String?
  // Whether this team member was also saved into the Directory as a Contact.
  contactId    String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

model CreativeAsset {
  id           String     @id @default(cuid())
  productionId String
  production   Production @relation("productionCreative", fields: [productionId], references: [id], onDelete: Cascade)
  type         String
  title        String
  url          String?
  description  String?
  sortOrder    Int        @default(0)
  // Image approval workflow (Phase 5). PENDING | APPROVED | DENIED.
  approvalStatus String?  @default("PENDING")
  approvedBy     String?
  approvedAt     DateTime?
  // Google Drive integration (Phase 6). driveFileId links this asset to a file
  // in the production's Drive folder; driveThumbnail caches Drive's thumbnail
  // URL. uploadedByName is the display name of whoever added it (tool upload or
  // the file's last modifier when synced from Drive). mimeType aids rendering.
  driveFileId    String?
  driveThumbnail String?
  uploadedByName String?
  mimeType       String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

model ScheduleBlock {
  id           String     @id @default(cuid())
  productionId String
  production   Production @relation("productionSchedule", fields: [productionId], references: [id], onDelete: Cascade)
  shootDay     Int        @default(1)
  time         String
  activity     String
  location     String?
  notes        String?
  sortOrder    Int        @default(0)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

model ProductionDeliverable {
  id           String     @id @default(cuid())
  productionId String
  production   Production @relation("productionDeliverables", fields: [productionId], references: [id], onDelete: Cascade)
  type         String
  title        String
  status       String     @default("AWAITING")
  dueDate      DateTime?
  url          String?
  notes        String?
  // Delivery format spec (Phase 4B). Pre-filled by deliverable type.
  resolution   String? // 4K | 1080p | 720p | Full-res | custom
  aspectRatio  String? // 16:9 | 4:5 | 1:1 | 9:16 | custom
  fileFormat   String? // MOV | MP4 | JPEG | TIFF | PSD | PNG | ProRes | custom
  colourSpace  String? // sRGB | AdobeRGB | P3 | Rec709
  // Shot numbers (from call-sheet shot lists) this deliverable is produced from.
  // e.g. ["1","2","3"] — a hero-image deliverable fed by shots 1-3.
  linkedShots  Json       @default("[]")
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

// A Campaign Timeline milestone — the FULL project timeline from pre-production
// through post-production and go-live. Distinct from the on-the-day shoot
// schedule (which lives on the call sheet). Status (PENDING / DONE / OVERDUE) is
// derived from `date` + `done` in the UI, not stored.
model ProductionMilestone {
  id           String     @id @default(cuid())
  productionId String
  production   Production @relation("productionMilestones", fields: [productionId], references: [id], onDelete: Cascade)
  phase        String     @default("PRE_PRODUCTION") // PRE_PRODUCTION | PRODUCTION | POST_PRODUCTION
  date         DateTime
  title        String
  description  String?
  done         Boolean    @default(false)
  // Rendered as a diamond/flag on the timeline (a key event — SHOOT DAY, go
  // live) rather than a task circle.
  isMilestone  Boolean    @default(false)
  // Set on rows seeded from a standard production template (see
  // src/lib/production-templates.ts). Used to recalculate their dates when the
  // shoot date changes and to avoid re-seeding duplicates.
  templateKey  String?
  // Sub-task nesting: a milestone can own child sub-tasks.
  parentId     String?
  parent       ProductionMilestone?  @relation("milestoneSubtasks", fields: [parentId], references: [id], onDelete: Cascade)
  subtasks     ProductionMilestone[] @relation("milestoneSubtasks")
  // Optional assignee — the Outlander team member responsible for this task.
  assignedTo   String?
  assignedUser User?      @relation("milestoneAssignee", fields: [assignedTo], references: [id])
  sortOrder    Int        @default(0)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

enum ProductionStatus {
  DRAFT
  BRIEFED
  PRE_PRODUCTION
  SHOOTING
  POST_PRODUCTION
  DELIVERED
  ARCHIVED
}

enum CallSheetStatus {
  DRAFT
  SAVED
  PUBLISHED
}

model CallSheet {
  id              String          @id @default(cuid())
  productionId    String
  production      Production      @relation(fields: [productionId], references: [id], onDelete: Cascade)
  status          CallSheetStatus @default(DRAFT)
  shootTitle      String?
  shootDate       DateTime
  callTime        String          @default("08:00")
  wrapTime        String?
  location        Json
  locationLat     Float?
  locationLng     Float?
  schedule        Json
  shotlist        Json            @default("[]")
  // Ordered list of shoot locations — supersedes the single `location` above.
  // [{ name, address, postcode, nearestAE, parkingNotes, contactPerson, whatThreeWords, mapLink, lat, lng }]
  // Order is the movement sequence for the day.
  locations       Json            @default("[]")
  // Overall shot style / creative approach: { tone, visualDevice, notes }
  shotStyle       Json            @default("{}")
  crew            Json
  talent          Json            @default("[]")
  cateringDetails Json            @default("{}")
  documents       Json            @default("[]")
  weatherData     Json?
  productionNotes String?
  safetyNotes     String?
  parkingNotes    String?
  notes           String? // legacy JSON blob — superseded by the dedicated columns above
  shareToken      String?         @unique
  clientShareToken String?        @unique // separate token for the redacted client version
  // ── Industry-standard call sheet sections (Jimmy Choo format) ──
  header            Json          @default("{}") // { productionCompany, jobNumber }
  clientTeam        Json          @default("[]") // [{ role, name }]
  agencyTeam        Json          @default("[]") // [{ role, name, phone, email }]
  productionCompany Json          @default("{}") // { name, address, execProducer, producer }
  callTimes         Json          @default("[]") // [{ time, department }]
  productionMobiles Json          @default("[]") // [{ role, name, phone }]
  movementOrder     Json          @default("{}") // { nearestStation, siteEntrance, techParking, crewParking, routeNotes }
  equipment         Json          @default("{}") // { cameraSupplier, cameraContact, cameraEmail, lightingSupplier, lightingContact, otherNotes }
  distributions   Json            @default("[]") // [{ name, role, email, sentAt, confirmedAt? }]
  distributedAt   DateTime?
  createdAt       DateTime        @default(now())
}

model ProductionExpense {
  id           String     @id @default(cuid())
  productionId String
  production   Production @relation(fields: [productionId], references: [id], onDelete: Cascade)
  category     String
  description  String
  amount       Float
  receiptUrl   String?
  approvedBy   String?
  createdAt    DateTime   @default(now())
}

model ProductionCrew {
  id           String     @id @default(cuid())
  productionId String
  production   Production @relation(fields: [productionId], references: [id], onDelete: Cascade)
  contactId    String
  contact      Contact    @relation(fields: [contactId], references: [id])
  role         String
  dayRate      Float?
  confirmed    Boolean    @default(false)
}

// ===== PRINT =====
model PrintIssue {
  id        String    @id @default(cuid())
  title     String
  year      Int
  pageCount Int       @default(0)
  status    String    @default("planning")
  printer   String?
  printDate DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  pages        PrintPage[]
  distribution PrintDistribution[]
}

model PrintPage {
  id         String     @id @default(cuid())
  issueId    String
  issue      PrintIssue @relation(fields: [issueId], references: [id], onDelete: Cascade)
  pageNumber Int
  type       String
  clientId   String?
  client     Client?    @relation(fields: [clientId], references: [id])
  assignedTo String?
  status     String     @default("planned")
  contentUrl String?
}

model PrintDistribution {
  id        String     @id @default(cuid())
  issueId   String
  issue     PrintIssue @relation(fields: [issueId], references: [id], onDelete: Cascade)
  warehouse String
  quantity  Int
  shippedAt DateTime?
  tracking  String?
}

// Embedded flat plan + line tracker for a magazine issue. `pages` holds the full
// page-by-page array (see src/lib/magazine-plan.ts for the page object shape).
model MagazinePlan {
  id          String   @id @default(cuid())
  issueNumber Int
  issueName   String
  totalPages  Int      @default(8)
  pages       Json     @default("[]")
  seedVersion Int      @default(0) // bumped when the seed blueprint changes, so seeded issues re-seed on next load
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  updatedBy   String?

  @@unique([issueNumber])
}

// ===== EDITORIAL =====
model EditorialPiece {
  id           String    @id @default(cuid())
  title        String
  type         String
  writerId     String?
  writer       User?     @relation("Writer", fields: [writerId], references: [id])
  editor       String?
  status       String    @default("pitch")
  deadline     DateTime?
  wordCount    Int?
  printPageId  String?
  publishedUrl String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  notes EditorialNote[]
}

model EditorialNote {
  id        String         @id @default(cuid())
  pieceId   String
  piece     EditorialPiece @relation(fields: [pieceId], references: [id], onDelete: Cascade)
  author    String
  content   String
  createdAt DateTime       @default(now())
}

// ===== EVENTS =====
model Event {
  id        String   @id @default(cuid())
  title     String
  type      String
  date      DateTime
  venue     String?
  capacity  Int?
  rsvpCount Int      @default(0)
  status    String   @default("planning")
  budget    Float?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  guests EventGuest[]
}

model EventGuest {
  id         String   @id @default(cuid())
  eventId    String
  event      Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  contactId  String?
  contact    Contact? @relation(fields: [contactId], references: [id])
  name       String
  email      String?
  rsvpStatus String   @default("invited")
  checkedIn  Boolean  @default(false)
}

// ===== SYNC ENGINE =====
model SyncStatus {
  id            String    @id @default(cuid())
  source        String    @unique
  lastSyncAt    DateTime?
  lastSuccessAt DateTime?
  nextSyncAt    DateTime?
  intervalMs    Int
  state         String    @default("idle") // idle | running | error | stale
  lastError     String?
  errorCount24h Int       @default(0)
  recordsSynced Int       @default(0)
  totalRuns     Int       @default(0)
  updatedAt     DateTime  @updatedAt
  createdAt     DateTime  @default(now())
}

model SyncLog {
  id          String    @id @default(cuid())
  source      String
  startedAt   DateTime  @default(now())
  finishedAt  DateTime?
  durationMs  Int?
  ok          Boolean   @default(false)
  recordCount Int       @default(0)
  message     String?
  meta        Json?

  @@index([source, startedAt])
}

// ===== INTELLIGENCE ENGINE =====
model IntelligenceLog {
  id         String    @id @default(cuid())
  runId      String
  campaignId String?
  campaign   Campaign? @relation(fields: [campaignId], references: [id])
  type       String // status_update | io_signed | value_update | flag | no_change | error
  finding    String
  action     String?
  confidence Float     @default(0)
  sources    String[]
  rawData    Json?
  createdAt  DateTime  @default(now())
}

// ===== RATE CARD =====
// Preset placements that pre-fill the media plan builder. Seeded with
// Outlander's default rate card; editable from admin.
model RateCardPlacement {
  id          String   @id @default(cuid())
  name        String   @unique
  rate        Float    @default(0)
  impressions Int      @default(0)
  rateType    String   @default("Flat Fee") // Flat Fee | Flat Post
  measurement String   @default("Impressions") // Impressions | Reach | N/A
  sortOrder   Int      @default(0)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ===== MEDIA PLANS =====
model MediaPlan {
  id           String    @id @default(cuid())
  campaignId   String?
  campaign     Campaign? @relation(fields: [campaignId], references: [id])
  clientName   String
  campaignName String
  flightStart  DateTime?
  flightEnd    DateTime?
  currency     String    @default("GBP")
  contactName  String?
  contactEmail String?
  status       String    @default("draft")
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  lineItems MediaPlanLineItem[]
}

// ===== DEADLINES =====
model Deadline {
  id              String    @id @default(cuid())
  title           String
  description     String?
  dueDate         DateTime
  source          String
  sourceRef       String?
  sourceUrl       String?
  type            String
  status          String    @default("ACTIVE")
  priority        String    @default("MEDIUM")
  category        String?
  assignedTo      String?
  user            User?     @relation("userDeadlines", fields: [assignedTo], references: [id])
  createdBy       String?
  emailFrom       String?
  emailSnippet    String?
  threadId        String?
  startDate       DateTime?
  linkedType      String?
  linkedId        String?
  rawData         Json?
  completedAt     DateTime?
  snoozedUntil    DateTime?
  escalatedAt     DateTime? // last time auto-ping raised this deadline
  escalationLevel Int       @default(0) // 0 none, 1 HIGH, 2 URGENT, 3 7-day alert sent
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@unique([source, sourceRef])
  @@index([dueDate])
  @@index([status])
}

model MediaPlanLineItem {
  id                String    @id @default(cuid())
  mediaPlanId       String
  mediaPlan         MediaPlan @relation(fields: [mediaPlanId], references: [id], onDelete: Cascade)
  site              String
  startDate         DateTime?
  endDate           DateTime?
  placement         String
  rate              Float     @default(0)
  rateType          String    @default("Flat Fee")
  discount          Float     @default(0)
  units             Int       @default(1)
  grossCost         Float     @default(0)
  netCost           Float     @default(0)
  projectedCreative String?
  deliveryStatus    String    @default("planned")
  sortOrder         Int       @default(0)
}

// ===== INSTAGRAM CONTENT TRACKER =====
model InstagramPost {
  id             String   @id @default(cuid())
  igId           String   @unique
  igAccountId    String
  caption        String?
  mediaType      String
  mediaUrl       String?
  thumbnailUrl   String?
  permalink      String?
  timestamp      DateTime
  likeCount      Int      @default(0)
  commentCount   Int      @default(0)
  reachCount     Int      @default(0)
  savesCount     Int      @default(0)
  sharesCount    Int      @default(0)
  viewsCount     Int      @default(0)
  engagementRate Float    @default(0)
  brands         String[] @default([])
  postType       String   @default("UNCLASSIFIED")
  campaignId     String?
  campaignName   String?
  notes          String?
  lastSynced     DateTime @default(now())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([igAccountId])
  @@index([timestamp])
  @@index([postType])
}

// ===== THINK TANK (Cultural Intelligence) =====
model TrendSignal {
  id         String   @id @default(cuid())
  title      String
  source     String
  sourceUrl  String?
  category   String
  summary    String?
  sentiment  String?
  relevance  Int      @default(50)
  trending   Boolean  @default(false)
  tags       String[] @default([])
  upvotes    Int      @default(0)
  flagged    Boolean  @default(false)
  aiAnalysis String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([category])
  @@index([source])
  @@index([createdAt])
}

model BrandWatch {
  id          String    @id @default(cuid())
  name        String
  category    String?
  description String?
  logoUrl     String?
  keywords    String[]  @default([])
  signalCount Int       @default(0)
  heatScore   Int       @default(50)
  trajectory  String    @default("stable")
  lastChecked DateTime?
  notes       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model TrendReport {
  id          String   @id @default(cuid())
  title       String
  type        String
  content     String
  period      String?
  brandId     String?
  generatedBy String   @default("ai")
  createdAt   DateTime @default(now())

  @@index([type])
  @@index([createdAt])
}

// ===== CULTURAL CALENDAR =====
model CulturalEvent {
  id          String    @id @default(cuid())
  title       String
  date        DateTime
  endDate     DateTime?
  category    String
  subcategory String?
  location    String?
  description String?
  source      String?
  sourceUrl   String?
  importance  Int       @default(50)
  recurring   Boolean   @default(false)
  tags        String[]  @default([])
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

// ===== FINANCE PORTAL (F1) =====
model CampaignBudget {
  id               String   @id @default(cuid())
  campaignId       String? // links to the Commercial pipeline deal (Campaign)
  trelloCardId     String? // links to Trello deal
  trelloCardName   String?
  clientName       String
  campaignName     String
  totalBudget      Float    @default(0)
  productionBudget Float    @default(0)
  mediaBudget      Float    @default(0)
  internalBudget   Float    @default(0)
  otherBudget      Float    @default(0)
  status           String   @default("DRAFT") // DRAFT, SUBMITTED, APPROVED, RECONCILED
  submittedBy      String? // userId
  approvedBy       String? // userId
  notes            String?
  productionId     String? // link to Production project
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([status])
  @@index([trelloCardId])
  @@index([productionId])
  @@index([campaignId])
}

model CostEntry {
  id               String   @id @default(cuid())
  campaignBudgetId String?
  budgetLineItemId String?  @unique // mirror of a Production BudgetLineItem's actual spend
  category         String // production, media, talent, location, equipment, catering, travel, internal, other
  description      String
  amount           Float
  vendor           String?
  date             DateTime @default(now())
  receipt          String? // URL to receipt/proof
  loggedBy         String? // userId
  portal           String? // which portal this was logged from: production, commercial, admin
  status           String   @default("LOGGED") // LOGGED, APPROVED, PAID
  xeroMatchId      String? // matched Xero transaction ID
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([campaignBudgetId])
  @@index([category])
  @@index([portal])
  @@index([status])
}

model InvoiceSubmission {
  id               String    @id @default(cuid())
  supplierName     String
  supplierEmail    String
  amount           Float?
  currency         String    @default("GBP")
  description      String?
  emailSubject     String?
  emailMessageId   String?   @unique // dedup
  attachmentUrl    String?
  receivedAt       DateTime  @default(now())
  paymentDeadline  DateTime // 30 days from received
  status           String    @default("RECEIVED") // RECEIVED, UNDER_REVIEW, APPROVED, PAID, REJECTED
  campaignBudgetId String? // project this invoice is coded to
  flagged          Boolean   @default(false)
  flagNote         String?
  reviewedBy       String?
  approvedBy       String?
  approvedAt       DateTime?
  paidAt           DateTime?
  xeroPaymentId    String? // matched Xero payment
  reminderSent     Boolean   @default(false)
  notes            String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([status])
  @@index([paymentDeadline])
  @@index([campaignBudgetId])
}
